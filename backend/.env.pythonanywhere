# DevSync - PythonAnywhere Environment Variables
# Copy this to .env and fill in your values

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-generate-a-new-one
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=YOUR_USERNAME.pythonanywhere.com

# CSRF and CORS (replace with your Vercel frontend URL)
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Database - PythonAnywhere MySQL (FREE!)
# Format: mysql://USERNAME:PASSWORD@USERNAME.mysql.pythonanywhere-services.com/USERNAME$DATABASE_NAME
DATABASE_URL=mysql://YOUR_USERNAME:YOUR_DB_PASSWORD@YOUR_USERNAME.mysql.pythonanywhere-services.com/YOUR_USERNAME$devsync

# AI Mode - Use smart_only for free hosting (no Ollama needed)
AI_MODE=smart_only

# Optional: Leave empty to use defaults
REDIS_URL=
OLLAMA_HOST=
