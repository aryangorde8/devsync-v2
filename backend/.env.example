# DevSync Backend Environment Variables
# Copy this file to .env and update values as needed

# =============================================================================
# SECURITY (REQUIRED for production)
# =============================================================================
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-use-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# CORS & CSRF (Update for production domain)
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# DATABASE
# =============================================================================
# Leave empty to use SQLite (default, free, no setup needed)
# For PostgreSQL, set the full connection URL:
# DATABASE_URL=postgres://user:password@localhost:5432/devsync_db

# Or set individual PostgreSQL settings:
# USE_POSTGRES=True
# POSTGRES_DB=devsync_db
# POSTGRES_USER=devsync_user
# POSTGRES_PASSWORD=your_secure_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# =============================================================================
# REDIS (Optional - for caching and Celery)
# =============================================================================
# Leave empty to use local memory cache (default, free)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CELERY (Optional - for background tasks)
# =============================================================================
# USE_CELERY=False

# =============================================================================
# EMAIL (Optional - for password reset, notifications)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# =============================================================================
# SENTRY (Optional - for error monitoring)
# =============================================================================
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# PRODUCTION DEPLOYMENT (Render, Railway, etc.)
# =============================================================================
# These are typically set automatically by the platform:
# DATABASE_URL=postgres://...
# REDIS_URL=redis://...
# DJANGO_SECRET_KEY=generated-secret-key
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-domain.com,*.onrender.com
