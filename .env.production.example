# =============================================================================
# DevSync - Production Environment Variables
# =============================================================================
# IMPORTANT: Never commit this file with real values to version control!
# Copy to .env and fill in your actual production values
# =============================================================================

# -----------------------------------------------------------------------------
# Core Django Settings
# -----------------------------------------------------------------------------
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=  # Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# -----------------------------------------------------------------------------
# CORS & CSRF (Update with your frontend domain)
# -----------------------------------------------------------------------------
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Option 1: Full DATABASE_URL (Render, Railway, Heroku style)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual credentials (Docker Compose style)
# USE_POSTGRES=True
# POSTGRES_DB=devsync_db
# POSTGRES_USER=devsync_user
# POSTGRES_PASSWORD=strong-password-here
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis (Optional - for caching & Celery)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379/0
# USE_CELERY=True
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Frontend URL (for Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry - Free tier available)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Cloud Storage (Optional - for media files)
# -----------------------------------------------------------------------------
# AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=

# Azure Blob Storage
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_CONTAINER_NAME=

# -----------------------------------------------------------------------------
# GitHub OAuth (Optional - for GitHub import feature)
# -----------------------------------------------------------------------------
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# API Rate Limiting (Production values)
# -----------------------------------------------------------------------------
# These override defaults in settings.py
# THROTTLE_BURST=60/min
# THROTTLE_SUSTAINED=1000/hour
