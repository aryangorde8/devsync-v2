###############################################################################
# Copy to terraform.tfvars and fill in your values
###############################################################################

# AWS region. Use the one closest to you.
#   ap-south-1 = Mumbai (cheapest for India)
#   us-east-1  = N. Virginia (cheapest globally)
aws_region = "ap-south-1"

# REQUIRED — your public IP in CIDR form. Find with: curl ifconfig.me
my_ip_cidr = "203.0.113.42/32"

# --- Student / demo defaults (cheapest stable setup) -------------------------
project_name            = "devsync"
environment             = "demo"
jenkins_instance_type   = "t3.small"   # ~$0.023/h ≈ $8 for 15 days if 24/7
sonarqube_instance_type = "t3.medium"  # ~$0.046/h — REQUIRED, less RAM = OOM
app_instance_type       = "t3.small"   # ~$0.023/h ≈ $8 for 15 days if 24/7
root_volume_size_gb     = 20           # ~$1.60/month per disk
use_elastic_ip          = false        # Saves $3.60/mo while instance is stopped
